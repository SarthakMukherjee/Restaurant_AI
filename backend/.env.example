# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/restaurant_ai

# --- Auth / JWT ---
SECRET_KEY=replace-with-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- GROQ AI ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS (comma-separated list handled as JSON array by pydantic-settings) ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500"]

# --- First-run admin bootstrap ---
FIRST_ADMIN_EMAIL=admin@restaurant.ai
FIRST_ADMIN_PASSWORD=AdminPass123!
FIRST_ADMIN_NAME=System Admin
